MYSQL_DATABASE=busdb
MYSQL_USER=bus
MYSQL_PASSWORD=replace-with-a-long-random-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-long-random-password
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/busdb?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=bus
SPRING_DATASOURCE_PASSWORD=replace-with-a-long-random-password
APP_JWT_SECRET=replace-with-a-long-random-32-plus-character-secret

# WhatsApp notifications are feature-flagged. Leave disabled until Gupshup credentials are ready.
APP_WHATSAPP_ENABLED=false

# Gupshup WhatsApp API config
APP_WHATSAPP_GUPSHUP_API_KEY=
APP_WHATSAPP_GUPSHUP_SOURCE_NUMBER=
APP_WHATSAPP_GUPSHUP_APP_NAME=
APP_WHATSAPP_GUPSHUP_TEMPLATE_ENDPOINT=https://api.gupshup.io/wa/api/v1/template/msg
APP_WHATSAPP_GUPSHUP_MESSAGE_ENDPOINT=https://api.gupshup.io/wa/api/v1/msg
APP_WHATSAPP_DEFAULT_COUNTRY_CODE=91
APP_WHATSAPP_TICKET_BASE_URL=https://travelranchi.com

# TEMPLATE sends an approved Gupshup/WhatsApp template and should be used for production confirmations.
# TEXT sends a free-form message inside WhatsApp's 24-hour customer-service window, useful for limited testing.
APP_WHATSAPP_MESSAGE_MODE=TEMPLATE
APP_WHATSAPP_TICKET_CONFIRMATION_TEMPLATE_ID=
APP_WHATSAPP_TICKET_CONFIRMATION_LANGUAGE_CODE=en
APP_WHATSAPP_TICKET_CONFIRMATION_TEMPLATE_PARAMS=passengerName,bookingReference,route,travelDate,departureTime,seatLabels,ticketUrl

# Optional only for APP_WHATSAPP_MESSAGE_MODE=TEXT.
# Supported placeholders: {{passengerName}}, {{bookingReference}}, {{route}}, {{travelDate}}, {{departureTime}}, {{seatLabels}}, {{ticketUrl}}
APP_WHATSAPP_TICKET_CONFIRMATION_TEXT_TEMPLATE=
