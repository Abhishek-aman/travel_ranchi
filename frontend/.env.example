# Local: backend on your machine
VITE_API_BASE_URL=http://localhost:8080
#
# Docker/production: use same-origin `/api` and let Caddy proxy requests to the backend.
# VITE_API_BASE_URL=__SAME_ORIGIN__
#
# Optional: used for customer totalAmount when trip has no price from API
VITE_FARE_PER_SEAT=499
#
# Guest checkout (no traveller sign-up): backend must implement POST /api/auth/guest-customer
# returning the same JSON as login (accessToken or access_token).
#
# Optional YouTube video id for the charter landing page embed (e.g. dQw4w9WgXcQ)
# VITE_CHARTER_PROMO_VIDEO_ID=
